{
  "name": "shop-pos",
  "version": "1.0.0",
  "description": "Offline-first stock management and billing (POS) desktop app.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "NODE_ENV=development concurrently \"npm run backend\" \"npm run frontend\" \"npm run electron\"",
    "backend": "cd backend && node server.js",
    "frontend": "cd frontend && npm run dev",
    "electron": "wait-on http://localhost:5173 && electron .",
    "build": "cd frontend && npm run build",
    "dist": "npm run build && electron-builder",
    "postinstall": "cd backend && npm install && cd ../frontend && npm install"
  },
  "build": {
    "appId": "com.shop.pos",
    "productName": "Shop POS",
    "files": ["electron/**/*", "backend/**/*", "frontend/dist/**/*", "!backend/*.db"],
    "asarUnpack": ["backend/node_modules/sqlite3/**/*"],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "wait-on": "^9.0.10"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
